// --------------- HTTP HANDLERS ----------------
void redirectHome() { server.sendHeader("Location", "/"); server.send(303); }

void handleRoot() { server.send(200, "text/html", htmlPage()); }

void handleScan() { doScan(false); redirectHome(); }
void handleDeepScan() { doScan(true); redirectHome(); }

void handleStop() {
  attacking = false;
  setLed(false);
  if (rogueApActive) {
    WiFi.softAPdisconnect(true);
    WiFi.mode(WIFI_AP_STA);
    rogueApActive = false;
  }
#if USE_NRF24
  if (nrfReady && nrfJamming) { radio.stopConstCarrier(); nrfJamming = false; }
#endif
  redirectHome();
}

void handleSettings() {
  if (server.hasArg("mode")) {
    int m = server.arg("mode").toInt();
    if (m >= 0 && m <= 8) attackMode = m;
  }
  if (server.hasArg("int")) intensity = constrain(server.arg("int").toInt(), 1, 50);
  if (server.hasArg("tx")) { txPower = constrain(server.arg("tx").toInt(), 8, 84); applyTxPower(); }
  if (server.hasArg("timer")) attackTimerSec = constrain(server.arg("timer").toInt(), 0, 3600);
  if (server.hasArg("ch")) channelFilter = constrain(server.arg("ch").toInt(), 0, 13);
  if (server.hasArg("rssi")) minRssi = constrain(server.arg("rssi").toInt(), -100, 0);
  if (server.hasArg("reason")) reasonCode = constrain(server.arg("reason").toInt(), 1, 24);
  if (server.hasArg("bidir")) biDirectional = server.arg("bidir").toInt() != 0;
  if (server.hasArg("clone")) cloneBeacons = server.arg("clone").toInt() != 0;
  if (server.hasArg("rand")) randomizeMac = server.arg("rand").toInt() != 0;
  if (server.hasArg("cycle")) autoCycle = server.arg("cycle").toInt() != 0;
  redirectHome();
}

void handleToggle() {
  if (server.hasArg("id")) {
    int id = server.arg("id").toInt();
    if (id >= 0 && id < scannedCount) nets[id].selected = !nets[id].selected;
  }
  redirectHome();
}

void handleSelectAll() {
  for (int i = 0; i < scannedCount; i++) nets[i].selected = passesFilter(i);
  redirectHome();
}

void handleSelectOpen() {
  for (int i = 0; i < scannedCount; i++)
    nets[i].selected = passesFilter(i) && (nets[i].enc == WIFI_AUTH_OPEN);
  redirectHome();
}

void handleSelectHidden() {
  for (int i = 0; i < scannedCount; i++)
    nets[i].selected = passesFilter(i) && (nets[i].ssid.length() == 0);
  redirectHome();
}

void handleInvert() {
  for (int i = 0; i < scannedCount; i++)
    if (passesFilter(i)) nets[i].selected = !nets[i].selected;
  redirectHome();
}

void handleClear() {
  for (int i = 0; i < scannedCount; i++) nets[i].selected = false;
  redirectHome();
}

void handleResetStats() {
  packetsSent = 0; deauthCount = 0; disassocCount = 0;
  beaconCount = 0; probeCount = 0; authCount = 0; actionCount = 0;
  pktsLastSec = 0; pktsWindow = 0; peakPktRate = 0;
  redirectHome();
}

void startAttack() {
  packetsSent = 0;
  pktsWindow = 0;
  pktsLastSec = 0;
  lastPktMs = millis();
  attackStartMs = millis();
  attacking = true;
  setLed(true);
  applyTxPower();
}

void handleAttack() {
  if (attackMode == MODE_BEACON || attackMode == MODE_PROBE || attackMode == MODE_AUTH ||
      attackMode == MODE_CSA || attackMode == MODE_EAPOL || attackMode == MODE_AMOK ||
      selectedCount() > 0) startAttack();
  redirectHome();
}

void handleAttackAll() {
  for (int i = 0; i < scannedCount; i++) nets[i].selected = passesFilter(i);
  if (scannedCount > 0 || attackMode >= MODE_BEACON) startAttack();
  redirectHome();
}

void handleAttackOne() {
  if (server.hasArg("id")) {
    int id = server.arg("id").toInt();
    if (id >= 0 && id < scannedCount) {
      for (int i = 0; i < scannedCount; i++) nets[i].selected = false;
      nets[id].selected = true;
      startAttack();
    }
  }
  redirectHome();
}

